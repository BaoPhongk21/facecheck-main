# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/
mobile/node_modules/

# Python Environment
ai-service/venv/
ai-service/__pycache__/
ai-service/*.pyc

# Build outputs
frontend/dist/
mobile/.expo/
mobile/web-build/

# Environment variables (IMPORTANT: Do not push secrets)
.env
backend/.env
ai-service/.env

# Databases & Local storage
*.db
*.sqlite
backend/prisma/dev.db

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# AI Models (If they are large, better download separately)
ai-service/models/*.pth
ai-service/models/*.onnx